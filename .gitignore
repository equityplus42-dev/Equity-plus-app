# ═══════════════════════════════════════════════════════════════════════════
#  ReferralSystem — Monorepo .gitignore
# ═══════════════════════════════════════════════════════════════════════════

# ── Node / Backend ──────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Environment files — NEVER commit secrets
.env
.env.*
!.env.example

# Coverage reports
coverage/
.nyc_output/

# Build output
dist/
build/

# ── Prisma ───────────────────────────────────────────────────────────────────
# Generated client is rebuilt in CI via `npx prisma generate`
backend/node_modules/

# ── Flutter / Dart ───────────────────────────────────────────────────────────
# Dart tool cache (generated)
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages

# Build output
build/
*.class

# Android generated
**/android/.gradle/
**/android/local.properties
**/android/key.properties
**/android/.cxx/
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
**/android/captures/

# iOS generated
**/ios/.symlinks/
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/ephemeral/
**/ios/Pods/
**/ios/Runner/GeneratedPluginRegistrant.*

# macOS
**/macos/Flutter/GeneratedPluginRegistrant.swift
**/macos/Flutter/ephemeral/

# Windows
**/windows/flutter/generated_plugin_registrant.cc
**/windows/flutter/generated_plugin_registrant.h
**/windows/flutter/generated_plugins.cmake

# Linux
**/linux/flutter/generated_plugin_registrant.cc
**/linux/flutter/generated_plugin_registrant.h
**/linux/flutter/generated_plugins.cmake

# Web
**/web/flutter_bootstrap.js

# ── IDEs ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws
.classpath
.project
.settings/

# ── OS generated ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Uploads / Temp ────────────────────────────────────────────────────────────
backend/src/uploads/temp/*
!backend/src/uploads/temp/.gitkeep

# ── Test artifacts ────────────────────────────────────────────────────────────
*.lcov

# ═══════════════════════════════════════════════════════════════════════════
#  DO NOT IGNORE:
#   - pubspec.lock    (ensures reproducible Flutter builds)
#   - package-lock.json (ensures reproducible Node builds)
# ═══════════════════════════════════════════════════════════════════════════
